# جلوگیری از اجرای مستقیم PHP و همچنین دانلود مستقیم بسته‌های zip قالب/افزونه
# (این فایل‌ها فقط باید توسط class-package-installer.php از روی دیسک خوانده
# شوند — .htaccess فقط دسترسی HTTP مستقیم را مسدود می‌کند، نه خواندن از PHP)
<FilesMatch "\.(php|zip)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>
