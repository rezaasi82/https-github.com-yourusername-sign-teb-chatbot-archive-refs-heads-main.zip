{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "signteb/before-after-slider",
  "version": "1.0.0",
  "title": "Before / After Slider",
  "category": "signteb-medical",
  "icon": "image-flip-horizontal",
  "description": "اسلایدر قبل/بعد — درگ و لمس — برای نتایج درمانی و جراحی",
  "textdomain": "signteb-blocks",
  "supports": { "html": false, "align": ["wide"] },
  "attributes": {
    "beforeImageId":  { "type": "number", "default": 0 },
    "afterImageId":   { "type": "number", "default": 0 },
    "beforeImageUrl": { "type": "string", "default": "" },
    "afterImageUrl":  { "type": "string", "default": "" },
    "beforeLabel":    { "type": "string", "default": "قبل" },
    "afterLabel":     { "type": "string", "default": "بعد" },
    "initialPosition":{ "type": "number", "default": 50 },
    "aspectRatio":    { "type": "string", "default": "3/2" },
    "caption":        { "type": "string", "default": "" }
  },
  "style":      "file:./style.css",
  "editorStyle":"file:./editor.css",
  "render":     "file:./render.php",
  "viewScript": "file:./view.js"
}
